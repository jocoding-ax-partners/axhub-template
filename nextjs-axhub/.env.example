# axhub bootstrap 이 배포 시 자동 주입해요 (lib/axhub-server.ts 의 {{...}} placeholder 치환).
# 로컬에서 직접 돌릴 때만 아래를 .env.local 에 채워 우선 적용해요.
#
# 클라이언트는 @ax-hub/sdk 의 AxHubClient — lib/axhub-server.ts 의 makeAxhub() 가 요청별로 생성.
# 인증: 사용자 세션 쿠키(_hub_access) 를 JWT 로 SDK 에 박아요 — 정적 API key 안 써요.

APPHUB_API_URL=https://api.axhub.ai
APPHUB_APP_SLUG=my-app-slug
APPHUB_TENANT=my-tenant

# 앱 자체 DB (raw-db). axhub 에서 이 앱의 raw DB 를 켜면(enable) 배포 시 자동 주입돼요.
# 로컬에서 직접 돌릴 때만 아래를 채워요 (예: 로컬 Postgres). lib/data.ts 의 query()/ownedTable() 이 이 값으로 붙어요.
DATABASE_URL=postgres://user:password@localhost:5432/my_app

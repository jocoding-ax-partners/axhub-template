---
import Layout from "../layouts/Layout.astro";
import { APP_SLUG, isAxhubConfigured, makeAxhub } from "../lib/axhub-server";

// SDK 2.x identity.me 응답. 로그인한 사용자 + 활성 테넌트 멤버십.
type Me = {
  userId: string;
  email: string;
  name?: string;
  tenants?: { tenantId: string; tenantSlug: string; role: string; isActive: boolean }[];
};

let me: Me | null = null;
if (isAxhubConfigured()) {
  try {
    // frontmatter(서버)에서 들어온 요청의 쿠키를 ctx 로 넘기면 SDK 가 JWT Bearer 로 포워딩해요.
    const sdk = makeAxhub({ cookie: Astro.request.headers.get("cookie") });
    me = (await sdk.identity.me()) as Me;
  } catch {
    /* noop — 아래에서 안내 */
  }
}
const tenant = me?.tenants?.[0];

/* ─────────────────────────────────────────────────────────────────────────────
 * 🤖 Claude Code / AI 에이전트 — 백엔드 호출 치트시트 (지우지 말 것)
 *
 * 화면을 깔끔히 하려고 아래 패턴들을 주석으로 내렸을 뿐, 이 앱에서 axhub 백엔드를
 * 쓸 때 그대로 쓰는 정식 패턴이다. 전부 서버(frontmatter)에서 호출한다.
 * Astro 는 전역 쿠키 접근이 없어서 Astro.request 의 쿠키를 ctx 로 넘긴다. SDK factory 가
 * _hub_access 를 Bearer 로 포워딩해 사용자 자격으로 호출한다. 정적 API 키 안 쓴다.
 *
 * 1) 내 정보 · sdk.identity.me  (위 환영 메시지가 이 호출 결과)
 *    import { makeAxhub } from "../lib/axhub-server";
 *    const sdk = makeAxhub({ cookie: Astro.request.headers.get("cookie") });
 *    const me = await sdk.identity.me(); // { email, name, tenants[] }
 *
 * 2) 앱 데이터 · sdk.data.discover  (스키마 자동 추론)
 *    import { table } from "../lib/axhub-server";
 *    const todos = await table<{ id: string; title: string }>("todos", {
 *      cookie: Astro.request.headers.get("cookie"),
 *    });
 *    const list = await todos.list({ limit: 20 });
 *    await todos.insert({ title: "할 일" });
 *
 * 원본 identity.me 응답을 그대로 보고 싶으면 /ssr 페이지 참고.
 * ───────────────────────────────────────────────────────────────────────────── */
---

<Layout title="axhub × Astro">
  <div class="glow" aria-hidden="true"></div>
  <main>
    {/* 히어로 */}
    <header class="hero">
      <div class="tile"><span class="sheen"></span><span>ax</span></div>
      <span class="badge">vibe-coding starter</span>
      <h1>axhub <span class="accent">×</span> Astro</h1>
      <p class="lede">백엔드 · 인증 · 배포가 이미 연결된 스타터예요. 화면만 만들면 돼요.</p>
    </header>

    {/* 환영 카드 — sdk.identity.me 결과 */}
    <section class="card welcome">
      {
        me ? (
          <Fragment>
            <span class="dot dot-ok" />
            <p class="hello">환영합니다, {me.name ?? me.email}님 👋</p>
            <p class="sub">
              {me.email}
              {tenant ? ` · ${tenant.tenantSlug} (${tenant.role})` : ""}
            </p>
          </Fragment>
        ) : (
          <Fragment>
            <span class="dot dot-warn" />
            <p class="warn">
              {isAxhubConfigured()
                ? "로그인 정보를 불러오지 못했어요. axhub 로그인 상태를 확인해 주세요."
                : "로컬 실행 중"}
            </p>
            {!isAxhubConfigured() && (
              <p class="sub">axhub 로 배포하면 로그인한 사용자가 여기 표시돼요.</p>
            )}
          </Fragment>
        )
      }
    </section>

    {/* 다음 단계 */}
    <div class="steps">
      <div class="step"><span class="num">1</span><p class="step-t">화면 만들기</p><code>src/pages/index.astro</code></div>
      <div class="step"><span class="num">2</span><p class="step-t">백엔드 호출</p><code>makeAxhub()</code></div>
      <div class="step"><span class="num">3</span><p class="step-t">배포</p><code>/axhub:deploy</code></div>
    </div>

    <footer>
      <p class="tech">Astro · Node · TypeScript</p>
      <p class="slug">
        원본 <code>/me</code> 응답: <a href="/ssr">/ssr</a> · 이 앱 슬러그:
        <code class="slug-code">{isAxhubConfigured() ? APP_SLUG : "(로컬 실행)"}</code>
      </p>
    </footer>
  </main>
</Layout>

<style>
  .glow {
    position: fixed;
    top: -12rem;
    left: 50%;
    transform: translateX(-50%);
    width: 40rem;
    height: 40rem;
    border-radius: 9999px;
    background: var(--primary-soft);
    opacity: 0.7;
    filter: blur(80px);
    pointer-events: none;
    z-index: -1;
  }
  main {
    max-width: 36rem;
    margin: 0 auto;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.75rem;
    padding: 5rem 1.5rem;
    text-align: center;
  }
  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .tile {
    position: relative;
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 14px;
    margin-bottom: 1.25rem;
    display: grid;
    place-items: center;
    color: #fff;
    font-weight: 700;
    font-size: 1.125rem;
    overflow: hidden;
    background: linear-gradient(135deg, var(--primary), var(--primary-hover));
    box-shadow: var(--shadow-lg, 0 10px 16px -4px rgba(0, 0, 0, 0.18));
  }
  .tile .sheen {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.25), transparent 55%);
  }
  .tile span:last-child {
    position: relative;
  }
  .badge {
    display: inline-block;
    background: var(--primary-soft);
    color: var(--primary);
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
  }
  h1 {
    font-size: 2.75rem;
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin: 1rem 0 0;
  }
  .accent {
    color: var(--primary);
  }
  .lede {
    color: var(--fg-muted);
    font-size: 0.95rem;
    line-height: 1.6;
    max-width: 24rem;
    margin: 0.65rem 0 0;
  }
  .card {
    width: 100%;
    background: var(--bg-content);
    border: 1px solid var(--border-default);
    border-radius: 16px;
    padding: 1.75rem;
    box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.08), 0 1px 2px -1px rgba(0, 0, 0, 0.06);
  }
  .dot {
    display: block;
    width: 0.625rem;
    height: 0.625rem;
    border-radius: 9999px;
    margin: 0 auto 0.75rem;
  }
  .dot-ok {
    background: var(--success);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--success) 25%, transparent);
  }
  .dot-warn {
    background: var(--warning);
  }
  .hello {
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    margin: 0;
  }
  .warn {
    font-size: 0.95rem;
    font-weight: 600;
    margin: 0;
  }
  .sub {
    color: var(--fg-muted);
    font-size: 0.875rem;
    margin: 0.4rem 0 0;
  }
  .steps {
    width: 100%;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
  }
  @media (max-width: 30rem) {
    .steps {
      grid-template-columns: 1fr;
    }
  }
  .step {
    background: var(--bg-content);
    border: 1px solid var(--border-default);
    border-radius: 12px;
    padding: 1rem;
    text-align: left;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .step:hover {
    border-color: var(--primary);
    box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.08);
  }
  .num {
    display: grid;
    place-items: center;
    width: 1.5rem;
    height: 1.5rem;
    border-radius: 9999px;
    background: var(--primary-soft);
    color: var(--primary);
    font-size: 0.75rem;
    font-weight: 700;
  }
  .step-t {
    font-size: 0.875rem;
    font-weight: 600;
    margin: 0.6rem 0 0.25rem;
  }
  .step code {
    font-size: 0.6875rem;
    color: var(--fg-subtle);
  }
  footer {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .tech {
    color: var(--fg-subtle);
    font-size: 0.75rem;
    margin: 0;
  }
  .slug {
    color: var(--fg-subtle);
    font-size: 0.6875rem;
    margin: 0;
  }
  .slug a {
    color: var(--primary);
    text-decoration: none;
  }
  .slug-code {
    background: var(--primary-soft);
    color: var(--primary);
    padding: 0.05rem 0.3rem;
    border-radius: 4px;
  }
</style>

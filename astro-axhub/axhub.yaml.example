# axhub.yaml.example
# 이 Astro 템플릿은 현재 astro.config.ts가 output: "server" + @astrojs/node standalone 어댑터예요.
# 즉 기본 예시는 Docker 런타임 배포입니다. 배포 시 이 파일을 axhub.yaml 로 복사해서 사용하세요.

version: axhub/v1
name: astro-axhub

runtime:
  port: 3000
  health_path: /healthz

build:
  deploy_method: docker
  strategy: auto
  framework: node
  install: npm ci
  build: npm run build
  start: npm start
  dockerfile: Dockerfile

# 선택: 배포 전 검증 명령. commands는 최대 10개예요.
ci:
  commands:
    - npm ci
    - npm run build
  # timeout은 1..600초 값만 허용되는 선택 필드예요.
  # timeout: 300

# Astro를 정적 사이트로 export한다면 AxHub static hosting으로 올릴 수 있어요.
# 1) astro.config.ts를 output: "static"(또는 기본 static)으로 바꾸고 Node adapter/server start 의존을 제거하세요.
# 2) 위 runtime 블록은 필요 없고, build 블록을 아래처럼 바꾸세요.
#
# build:
#   deploy_method: static
#   static_output_dir: dist
#   strategy: auto
#   framework: node
#   install: npm ci
#   build: npm run build
#
# static_output_dir는 Vite/Astro 기본 출력인 dist를 사용해요.
# build 결과물은 static release로 발행되고 https://{app}--{tenant}.axhub.page 에서 서빙됩니다.

# axhub bootstrap 이 배포 시 자동 주입해요 (lib/axhub.ts 의 {{...}} placeholder 치환).
# 로컬에서 직접 돌릴 때만 아래를 .env 에 채워 우선 적용해요.

# ── 데이터베이스 (표준 PostgreSQL) ───────────────────────────────────────────
# 로컬: `docker compose up -d` 로 Postgres 를 띄운 뒤 아래 값을 그대로 쓰면 돼요.
# 배포: axhub 가 전용 DB 를 발급하고 DATABASE_URL / DIRECT_DATABASE_URL 을 자동 주입해요
#       (axhub.yaml 의 `database: { engine: postgres }` 선언이 트리거).
DATABASE_URL=postgres://postgres:postgres@localhost:5432/app
# DIRECT_DATABASE_URL 은 스키마 초기화/마이그레이션용 — 로컬은 비워두면 DATABASE_URL 로 폴백돼요.
# DIRECT_DATABASE_URL=

# ── 인증/식별 — @ax-hub/sdk 용 ───────────────────────────────────────────────
# axhub 인증은 사용자 세션 쿠키(_hub_access)를 포워딩해 동작해요 — 정적 API key 안 써요.
APPHUB_API_URL=https://api.axhub.ai
APPHUB_APP_SLUG=my-app-slug
APPHUB_TENANT=my-tenant

# axhub.yaml.example
# Vite는 기본적으로 정적 파일을 dist/에 생성하므로 AxHub static hosting에 바로 올릴 수 있어요.
# 배포 시 이 파일을 axhub.yaml 로 복사해서 사용하세요.

version: axhub/v1
name: vite-react-axhub

build:
  # static: Git build 결과물을 static release로 발행하고 *.axhub.page에서 서빙해요.
  # Vite / Astro static export처럼 서버 런타임이 필요 없는 앱에 사용하세요.
  deploy_method: static

  # Vite 기본 출력 디렉토리입니다. 다른 디렉토리를 쓰면 여기를 바꾸세요.
  static_output_dir: dist

  # auto 기본값. 명시하면 탐지 실패 시에도 Node 빌드 환경을 사용해요.
  strategy: auto
  framework: node

  # package-lock.json이 있으면 기본값도 npm ci를 실행하지만, 명시해두면 사용자가 더 이해하기 쉬워요.
  install: npm ci
  build: npm run build

# VITE_* 값은 브라우저 번들에 들어가므로 build scope로 주입해요.
# 아래 값들은 AxHub가 배포 시 자동 주입할 수 있는 선택 env예요.
env:
  optional:
    - name: VITE_APPHUB_API_URL
      scope: build
    - name: VITE_APPHUB_APP_SLUG
      scope: build
    - name: VITE_APPHUB_TENANT
      scope: build
    - name: VITE_APPHUB_APP_ORIGIN
      scope: build

# 선택: 배포 전 검증 명령. commands는 최대 10개예요.
ci:
  commands:
    - npm ci
    - npm run build
  # timeout은 1..600초 값만 허용되는 선택 필드예요.
  # timeout: 300

# Docker/K8s 런타임으로 배포하고 싶다면 static 대신 아래처럼 바꾸세요.
# runtime:
#   port: 80
#   health_path: /
# build:
#   deploy_method: docker
#   dockerfile: Dockerfile
